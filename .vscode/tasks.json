{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "uv: run active file",
      "type": "shell",
      "command": "uv",
      "args": ["run", "${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
